# ~/.dotfiles/config/mako/config
# Minimal, modern notifications tuned to your Hyprland aesthetic

font=JetBrainsMono Nerd Font 11
background-color=#12121ACC
text-color=#e6e6ffEE
progress-color=#313244FF

border-size=0
border-radius=16
padding=12
margin=10
width=320
height=62
max-icon-size=32
default-timeout=4200
ignore-timeout=0

anchor=top-right
layer=overlay
sort=-time

[urgency=low]
background-color=#101019CC
border-color=#00000000

default-timeout=4200

[urgency=normal]
background-color=#131326CC
border-color=#cba6f7AA

default-timeout=4200

[urgency=high]
background-color=#161426DD
border-color=#f38ba8CC
font=JetBrainsMono Nerd Font 12

default-timeout=0
